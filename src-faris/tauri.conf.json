{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hadirin",
  "version": "0.2.0",
  "identifier": "id.opensource.hadirin",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hadirin",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Education",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Input dan rekap absensi siswa per jam pelajaran.",
    "longDescription": "Hadirin membantu operator sekolah merekap absensi siswa dari buku absen fisik ke laporan digital tanpa backend dan tanpa biaya server."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU2QUI1RUEyODM2OTc2OTQKUldTVWRtbURvbDZyNWkyZ1lpaVMvaC9Ia0QxRU1YUkZPQnRoa1dhdG5Kd0ZreEd2OVZVaWllSU8K",
      "endpoints": [
        "https://github.com/farishhz/Hadirin/releases/latest/download/latest.json"
      ]
    }
  }
}